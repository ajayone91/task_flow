// ===================== HABITS (REAL DATA) =====================
let selectedHabitEmoji = '🧘';
function selectHabitEmoji(el, emoji) {
  document.querySelectorAll('.habit-emoji-opt').forEach(e=>e.classList.remove('active'));
  el.classList.add('active');
  selectedHabitEmoji = emoji;
}
function saveHabit() {
  const name = document.getElementById('habitName').value.trim();
  if(!name){ showToast('Enter a habit name','error'); return; }
  // Build 7-day done array: all 0 for new habit
  const today = new Date();
  const habit = {
    id: Date.now(),
    name,
    emoji: selectedHabitEmoji,
    streak: 0,
    done: [0,0,0,0,0,0,0], // last 7 days
    createdAt: today.toISOString()
  };
  habitsData.push(habit);
  document.getElementById('habitName').value = '';
  // reset emoji selection
  document.querySelectorAll('.habit-emoji-opt').forEach(e=>e.classList.remove('active'));
  document.querySelector('.habit-emoji-opt').classList.add('active');
  selectedHabitEmoji = '🧘';
  closeModal('habitModal');
  renderHabits();
  saveState();
  showToast('Habit added! 🎯','success');
}
function deleteHabit(hi) {
  if(!confirm('Delete this habit?')) return;
  habitsData.splice(hi,1);
  renderHabits();
  saveState();
  showToast('Habit removed','info');
}
function calcStreak(done) {
  // Count consecutive days from today backwards
  let streak = 0;
  for(let i=done.length-1;i>=0;i--){
    if(done[i]) streak++; else break;
  }
  return streak;
}
const days=['M','T','W','T','F','S','S'];
function renderHabits() {
  const el = document.getElementById('habitList');
  if(!habitsData.length){
    el.innerHTML=`<div class="empty-state"><div class="empty-icon">🌱</div><div class="empty-text">No habits yet — add your first one!</div><button class="btn-primary" onclick="openModal('habitModal')">+ Add Habit</button></div>`;
    return;
  }
  el.innerHTML=habitsData.map((h,hi)=>{
    const streak = calcStreak(h.done);
    return `<div class="habit-row">
    <span style="font-size:20px;flex-shrink:0">${h.emoji||'🎯'}</span>
    <div style="flex:1;font-size:14px;font-weight:600">${h.name}</div>
    <div style="font-size:12px;color:var(--orange);font-weight:700;margin-right:8px">🔥 ${streak}d</div>
    <div style="display:flex;gap:4px">${h.done.map((d,i)=>`<div class="habit-dot ${d?'done':''}" title="${days[i]}" onclick="toggleHabit(${hi},${i})">${d?'✓':days[i]}</div>`).join('')}</div>
    <div class="t-act del" onclick="deleteHabit(${hi})" style="margin-left:8px;opacity:.5;transition:opacity .2s" onmouseenter="this.style.opacity=1" onmouseleave="this.style.opacity=.5" title="Delete habit">🗑</div>
  </div>`;
  }).join('');
  // Update radar chart if visible
  try { initHabitChart(); } catch(e){}
}
function toggleHabit(hi,di){
  habitsData[hi].done[di]=habitsData[hi].done[di]?0:1;
  renderHabits();
  saveState();
  showToast('Habit updated! 🎯','success');
}

function updateRewards() {
  const done=tasks.filter(t=>t.done).length;
  const level=Math.max(1,Math.floor(done/5)+1);
  const xp=done*100; const nextLevelXP=level*500;
  const pct=Math.min(100,Math.round(((xp%(500))/500)*100));
  const el1=document.getElementById('rewardsLevelTitle');
  const el2=document.getElementById('rewardsXPSub');
  const el3=document.getElementById('rewardsXPFill');
  if(el1) el1.textContent='Level '+level+' Achiever 🏆';
  if(el2) el2.textContent=xp+' XP · '+(nextLevelXP-xp)+' XP to Level '+(level+1);
  if(el3) el3.style.width=pct+'%';
}

// ===================== BADGES =====================
function getBadges() {
  const done=tasks.filter(t=>t.done).length;
  const level=Math.max(1,Math.floor(done/5)+1);
  const maxStreak=(typeof habitsData!=='undefined'&&habitsData.length)?habitsData.reduce((mx,h)=>Math.max(mx,calcStreak(h.done)),0):0;
  const highDone=tasks.filter(t=>t.done&&t.pri==='high').length;
  const studyDone=tasks.filter(t=>t.done&&t.cat==='study').length;
  const fitDone=tasks.filter(t=>t.done&&(t.cat==='fitness'||t.cat==='health')).length;
  return [
    {icon:'🔥',name:'Streak Starter',desc:'3 day habit streak',locked:maxStreak<3},
    {icon:'⚡',name:'Speed Runner',desc:'Complete 10 tasks',locked:done<10},
    {icon:'🎯',name:'On Target',desc:'Complete your first task',locked:done<1},
    {icon:'🧠',name:'Deep Thinker',desc:'5 study tasks done',locked:studyDone<5},
    {icon:'💪',name:'Fitness Buff',desc:'10 health/fitness tasks',locked:fitDone<10},
    {icon:'🏆',name:'Champion',desc:'Reach Level 5',locked:level<5},
    {icon:'🚀',name:'Rocket Ship',desc:'Complete 50 tasks',locked:done<50},
    {icon:'💎',name:'Diamond',desc:'7 day habit streak',locked:maxStreak<7},
    {icon:'🌟',name:'All-Star',desc:'Complete 100 tasks',locked:done<100},
  ];
}
function renderBadges() {
  const badges=getBadges();
  document.getElementById('badgeGrid').innerHTML=badges.map(b=>`<div class="badge-item ${b.locked?'locked':''}">
    <div class="badge-icon">${b.icon}</div>
    <div style="font-size:12px;font-weight:700;margin-bottom:3px">${b.name}</div>
    <div style="font-size:11px;color:var(--muted)">${b.desc}</div>
    ${!b.locked?'<div style="font-size:10px;color:var(--green);margin-top:4px;font-weight:700">✓ Unlocked</div>':''}
  </div>`).join('');
}

