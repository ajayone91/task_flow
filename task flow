async function sendAI() {
  const inp = document.getElementById('aiInput');
  const msg = inp.value.trim(); if(!msg) return;
  inp.value='';
  appendMsg('user', msg);
  // Check for task add command
  const taskMatch = msg.match(/add task[:\s]+(.+?)(?:,\s*(work|personal|study|health|finance|fitness))?(?:,\s*(high|mid|medium|low))?(?:,\s*due\s*(.+))?$/i);
  if(taskMatch) {
    const title = taskMatch[1].trim();
    const cat = (taskMatch[2]||'personal').toLowerCase().replace('medium','mid');
    const pri = (taskMatch[3]||'mid').toLowerCase().replace('medium','mid');
    const due = taskMatch[4]?new Date(taskMatch[4]).toISOString().slice(0,10):'';
    tasks.unshift({id:Date.now(),title,desc:'',cat,pri,done:false,due,time:1,subtasks:[]});
    renderAll(); saveState();
    appendMsg('bot', `✅ Task added! **"${title}"** — ${cat} category, ${pri} priority${due?', due '+due:''}.\n\nHead to the Tasks view to see it! 🎯`);
    return;
  }
  showTyping();
  try {
    const systemPrompt = `You are an intelligent productivity AI assistant for TaskFlow AI app. You help users manage tasks, track skills, and improve productivity. Be friendly, concise, and actionable. Always speak in the user's context. ${getTaskSummary()} When suggesting tasks, say exactly what you recommend. Use emojis naturally. If asked about skills, reference the actual skill data. Keep responses under 200 words.`;
    const resp = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:400,
        system: systemPrompt,
        messages: [...aiMsgs.filter(m=>m.role).map(m=>({role:m.role,content:m.content})),{role:'user',content:msg}]
      })
    });
    const data = await resp.json();
    removeTyping();
    const reply = data.content?.[0]?.text || "I couldn't process that. Try again!";
    appendMsg('bot', reply);
    aiMsgs.push({role:'user',content:msg},{role:'assistant',content:reply});
    if(aiMsgs.length>20) aiMsgs=aiMsgs.slice(-20);
  } catch(e) {
    removeTyping();
    appendMsg('bot', "⚡ Couldn't connect to AI right now. But I can still help: you have **"+tasks.filter(t=>!t.done).length+" pending tasks**. Want me to prioritize them?");
  }
}

