<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>TaskFlow AI — Ultra</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#070910;--bg2:#0E1118;--bg3:#14181F;--bg4:#1A1F2B;--bg5:#202637;
  --blue:#4D8EFF;--purple:#7C5CFC;--cyan:#00D4FF;--pink:#FF4D9E;
  --green:#1AE47C;--orange:#FF9F1C;--red:#FF4560;--yellow:#FFD60A;
  --text:#EEF0FF;--muted:#5C647A;--border:rgba(255,255,255,0.06);
  --glass:rgba(255,255,255,0.03);--glass2:rgba(255,255,255,0.07);
  --glow-blue:rgba(77,142,255,0.3);--glow-purple:rgba(124,92,252,0.3);
  --glow-pink:rgba(255,77,158,0.25);--glow-cyan:rgba(0,212,255,0.2);
  --sidebar-w:260px;--topbar-h:62px;
  --ease:cubic-bezier(.4,0,.2,1);
}
[data-theme="day"]{
  --bg:#F0F4FF;--bg2:#FFFFFF;--bg3:#F5F7FF;--bg4:#EBEFff;--bg5:#E2E8FF;
  --text:#0D1128;--muted:#8892B0;--border:rgba(0,0,30,0.08);
  --glass:rgba(0,0,30,0.02);--glass2:rgba(0,0,30,0.05);
}
html,body{height:100%;font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);overflow:hidden;transition:background .4s var(--ease),color .3s}

/* SCROLLBAR */
::-webkit-scrollbar{width:3px;height:3px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px}

/* NOISE OVERLAY */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");opacity:0.4;pointer-events:none;z-index:9999}

/* LAYOUT */
.app{display:flex;height:100vh;width:100vw;overflow:hidden;position:relative}

/* AMBIENT GLOW */
.ambient{position:fixed;pointer-events:none;z-index:0;border-radius:50%;filter:blur(80px);opacity:.15}
.amb-1{width:500px;height:500px;background:var(--blue);top:-200px;left:-100px}
.amb-2{width:400px;height:400px;background:var(--purple);bottom:-150px;right:-100px}
.amb-3{width:300px;height:300px;background:var(--cyan);top:50%;left:50%;transform:translate(-50%,-50%)}

/* ===================== SIDEBAR ===================== */
.sidebar{width:var(--sidebar-w);min-width:var(--sidebar-w);background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;transition:all .35s var(--ease);z-index:20;position:relative;overflow:hidden}
.sidebar::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--blue),transparent);opacity:.4}
.sidebar.collapsed{width:68px;min-width:68px}

.logo-wrap{padding:20px 18px 16px;display:flex;align-items:center;gap:12px;cursor:pointer;flex-shrink:0}
.logo-icon{width:36px;height:36px;border-radius:12px;background:linear-gradient(135deg,var(--blue),var(--purple));display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;box-shadow:0 0 24px var(--glow-blue);position:relative}
.logo-icon::after{content:'';position:absolute;inset:-2px;border-radius:13px;background:linear-gradient(135deg,var(--blue),var(--purple));z-index:-1;opacity:.3;filter:blur(6px)}
.logo-txt{font-size:15px;font-weight:800;letter-spacing:-.02em;white-space:nowrap;overflow:hidden;transition:opacity .2s,width .3s;background:linear-gradient(135deg,var(--blue),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.sidebar.collapsed .logo-txt{opacity:0;width:0}

.nav-section{padding:8px 0}
.nav-sec-label{font-size:9px;font-weight:700;letter-spacing:.14em;color:var(--muted);text-transform:uppercase;padding:8px 20px 5px;white-space:nowrap;overflow:hidden;transition:opacity .2s}
.sidebar.collapsed .nav-sec-label{opacity:0}

.nav-item{display:flex;align-items:center;gap:12px;padding:10px 18px;cursor:pointer;transition:all .2s var(--ease);position:relative;overflow:hidden;white-space:nowrap;margin:1px 8px;border-radius:12px}
.nav-item:hover{background:var(--glass2)}
.nav-item.active{background:linear-gradient(135deg,rgba(77,142,255,.12),rgba(124,92,252,.08))}
.nav-item.active::before{content:'';position:absolute;left:0;top:20%;height:60%;width:3px;background:linear-gradient(180deg,var(--blue),var(--purple));border-radius:0 3px 3px 0}
.nav-icon{width:20px;height:20px;flex-shrink:0;opacity:.5;transition:opacity .2s}
.nav-item:hover .nav-icon,.nav-item.active .nav-icon{opacity:1}
.nav-label{font-size:13.5px;font-weight:600;transition:opacity .2s,width .3s;overflow:hidden}
.nav-item.active .nav-label{color:var(--blue)}
.sidebar.collapsed .nav-label{opacity:0;width:0}
.nav-badge{margin-left:auto;background:linear-gradient(135deg,var(--blue),var(--purple));color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;flex-shrink:0;box-shadow:0 2px 8px var(--glow-blue)}
.sidebar.collapsed .nav-badge{display:none}

.sidebar-bottom{margin-top:auto;padding:12px;border-top:1px solid var(--border)}
.user-card{display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px;border-radius:14px;transition:background .2s;position:relative}
.user-card:hover{background:var(--glass2)}
.avatar{width:36px;height:36px;border-radius:12px;background:linear-gradient(135deg,var(--purple),var(--blue));display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;overflow:hidden;border:2px solid rgba(255,255,255,.1)}
.avatar img{width:100%;height:100%;object-fit:cover;border-radius:10px}
.user-info{overflow:hidden;flex:1}
.user-name{font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:opacity .2s}
.user-role{font-size:11px;color:var(--muted)}
.sidebar.collapsed .user-info{display:none}
.logout-btn{padding:5px;border-radius:8px;background:var(--glass2);border:1px solid var(--border);cursor:pointer;color:var(--muted);font-size:12px;transition:all .2s;display:flex;align-items:center;justify-content:center}
.logout-btn:hover{color:var(--red);border-color:rgba(255,69,96,.3);background:rgba(255,69,96,.06)}
.sidebar.collapsed .logout-btn{display:none}

.xp-wrap{margin-top:8px;padding:0 2px}
.xp-row{display:flex;justify-content:space-between;font-size:10px;color:var(--muted);margin-bottom:5px}
.xp-track{background:var(--bg3);border-radius:20px;height:5px;overflow:hidden}
.xp-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--cyan));border-radius:20px;transition:width .8s var(--ease)}
.sidebar.collapsed .xp-wrap{display:none}

/* ===================== MAIN ===================== */
.main{flex:1;overflow:hidden;display:flex;flex-direction:column;position:relative;z-index:1}

/* TOPBAR */
.topbar{height:var(--topbar-h);background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 22px;gap:14px;flex-shrink:0;position:relative}
.topbar::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent)}
.topbar-title{font-size:17px;font-weight:800;letter-spacing:-.02em;flex:1}
.search-wrap{display:flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:8px 14px;width:220px;transition:all .2s;flex-shrink:0}
.search-wrap:focus-within{border-color:rgba(77,142,255,.4);box-shadow:0 0 0 3px rgba(77,142,255,.07);width:260px}
.search-wrap input{background:none;border:none;outline:none;color:var(--text);font-size:13px;font-family:'Outfit',sans-serif;width:100%}
.search-wrap input::placeholder{color:var(--muted)}
.icon-btn{width:36px;height:36px;border-radius:11px;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;flex-shrink:0;color:var(--muted)}
.icon-btn:hover{background:var(--bg4);border-color:rgba(77,142,255,.3);color:var(--text)}
.theme-btn{font-size:16px}
.notif-btn{position:relative}
.notif-btn::after{content:'3';position:absolute;top:-4px;right:-4px;width:16px;height:16px;background:var(--red);border-radius:50%;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;color:#fff;border:2px solid var(--bg2)}
.new-task-btn{background:linear-gradient(135deg,var(--blue),var(--purple));border:none;color:#fff;font-size:13px;font-weight:700;padding:9px 18px;border-radius:12px;cursor:pointer;display:flex;align-items:center;gap:6px;transition:all .2s;box-shadow:0 4px 16px var(--glow-blue);font-family:'Outfit',sans-serif;white-space:nowrap}
.new-task-btn:hover{transform:translateY(-1px);box-shadow:0 6px 20px var(--glow-blue)}
.new-task-btn:active{transform:translateY(0) scale(.98)}

/* CONTENT */
.content{flex:1;overflow-y:auto;padding:22px}

/* VIEWS */
.view{display:none;animation:viewIn .35s var(--ease)}
.view.active{display:block}
@keyframes viewIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

/* CARDS */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:18px;padding:20px;position:relative;overflow:hidden;transition:border-color .2s}
.card:hover{border-color:rgba(77,142,255,.15)}
.card-glow{position:absolute;pointer-events:none;border-radius:50%;filter:blur(50px);opacity:.2}

/* STATS GRID */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:18px;padding:18px;position:relative;overflow:hidden;transition:all .25s var(--ease);cursor:default}
.stat-card:hover{transform:translateY(-3px);border-color:rgba(77,142,255,.25);box-shadow:0 12px 40px rgba(0,0,0,.25)}
.stat-icon{width:42px;height:42px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:19px;margin-bottom:14px}
.stat-val{font-size:30px;font-weight:800;margin-bottom:3px;letter-spacing:-.03em}
.stat-label{font-size:12px;color:var(--muted);font-weight:500}
.stat-change{font-size:11px;margin-top:8px;display:flex;align-items:center;gap:4px;font-weight:600}
.stat-change.up{color:var(--green)}.stat-change.down{color:var(--red)}

/* GRIDS */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px}
.grid-3{display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:20px}

/* SECTION HEADERS */
.sec-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.sec-title{font-size:14px;font-weight:700;letter-spacing:-.01em}
.sec-action{font-size:12px;color:var(--blue);cursor:pointer;font-weight:600;transition:opacity .2s}
.sec-action:hover{opacity:.7}

/* WELCOME HERO */
.hero{background:linear-gradient(135deg,rgba(77,142,255,.1),rgba(124,92,252,.08),rgba(0,212,255,.05));border:1px solid rgba(77,142,255,.15);border-radius:22px;padding:26px 30px;margin-bottom:20px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-80px;right:-80px;width:250px;height:250px;background:radial-gradient(circle,var(--glow-blue),transparent 70%);pointer-events:none}
.hero-greet{font-size:24px;font-weight:800;margin-bottom:5px;letter-spacing:-.03em}
.hero-sub{font-size:13px;color:var(--muted);margin-bottom:18px}
.hero-badges{display:flex;gap:10px;flex-wrap:wrap}
.hero-badge{display:inline-flex;align-items:center;gap:6px;padding:5px 13px;border-radius:20px;font-size:12px;font-weight:700;border:1px solid}

/* TASKS */
.task-input-row{display:flex;gap:10px;margin-bottom:18px}
.task-input{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:14px;padding:13px 17px;color:var(--text);font-size:14px;font-family:'Outfit',sans-serif;outline:none;transition:all .2s}
.task-input:focus{border-color:rgba(77,142,255,.5);box-shadow:0 0 0 4px rgba(77,142,255,.07)}
.task-input::placeholder{color:var(--muted)}
.btn-primary{background:linear-gradient(135deg,var(--blue),var(--purple));border:none;color:#fff;font-size:13px;font-weight:700;padding:11px 20px;border-radius:13px;cursor:pointer;white-space:nowrap;transition:all .2s;font-family:'Outfit',sans-serif;box-shadow:0 4px 14px var(--glow-blue)}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 6px 18px var(--glow-blue)}
.btn-primary:active{transform:scale(.98)}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--muted);font-size:13px;padding:11px 16px;border-radius:13px;cursor:pointer;transition:all .2s;font-family:'Outfit',sans-serif;font-weight:600}
.btn-ghost:hover{background:var(--glass2);color:var(--text);border-color:rgba(77,142,255,.3)}

.task-filters{display:flex;gap:7px;margin-bottom:16px;flex-wrap:wrap}
.filter-chip{font-size:12px;padding:6px 14px;border-radius:20px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:all .2s;font-family:'Outfit',sans-serif;font-weight:600}
.filter-chip:hover{border-color:rgba(77,142,255,.4);color:var(--text)}
.filter-chip.active{background:rgba(77,142,255,.15);border-color:rgba(77,142,255,.5);color:var(--blue)}

/* TASK ITEM */
.task-item{background:var(--bg3);border:1px solid var(--border);border-radius:14px;padding:14px 16px;display:flex;align-items:flex-start;gap:12px;margin-bottom:8px;transition:all .25s var(--ease);cursor:pointer;position:relative;overflow:hidden}
.task-item:hover{border-color:rgba(77,142,255,.2);background:var(--bg4);transform:translateX(3px)}
.task-item.done{opacity:.5}
.task-item.done .task-title{text-decoration:line-through;color:var(--muted)}
.task-body{flex:1;min-width:0}
.task-title{font-size:14px;font-weight:600;margin-bottom:5px;line-height:1.4}
.task-meta-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.check-circle{width:22px;height:22px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .25s;margin-top:2px}
.check-circle:hover{border-color:var(--green);box-shadow:0 0 0 4px rgba(26,228,124,.1)}
.check-circle.done{background:var(--green);border-color:var(--green);box-shadow:0 0 12px rgba(26,228,124,.3)}
.check-circle.done::after{content:'✓';color:#fff;font-size:11px;font-weight:800}
.priority-badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:7px;text-transform:uppercase;letter-spacing:.04em}
.p-high{background:rgba(255,69,96,.15);color:var(--red)}
.p-mid{background:rgba(255,159,28,.15);color:var(--orange)}
.p-low{background:rgba(26,228,124,.15);color:var(--green)}
.cat-tag{font-size:10px;color:var(--muted);display:flex;align-items:center;gap:4px;font-weight:600}
.cat-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.due-tag{font-size:11px;color:var(--muted);font-weight:500}
.due-tag.overdue{color:var(--red)}
.task-actions{display:flex;gap:4px;opacity:0;transition:opacity .2s;margin-left:auto;flex-shrink:0}
.task-item:hover .task-actions{opacity:1}
.t-act{width:28px;height:28px;border-radius:9px;background:var(--bg4);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:12px;transition:all .2s}
.t-act:hover{background:var(--glass2);border-color:rgba(77,142,255,.3)}
.t-act.del:hover{background:rgba(255,69,96,.08);border-color:rgba(255,69,96,.3)}
.t-act.sub:hover{background:rgba(77,142,255,.08);border-color:rgba(77,142,255,.4)}
.t-act.expand:hover{background:rgba(124,92,252,.08)}

/* SUBTASKS — JELLY / SPRING LAYER */
.subtask-container{margin-top:8px;margin-left:34px;overflow:hidden;max-height:0;transition:max-height .45s cubic-bezier(.34,1.56,.64,1)}
.subtask-container.open{max-height:500px}
.subtask-add-row{display:flex;gap:8px;margin-bottom:7px}
.subtask-input{flex:1;background:var(--bg4);border:1px solid var(--border);border-radius:10px;padding:8px 12px;color:var(--text);font-size:12px;font-family:'Outfit',sans-serif;outline:none;transition:border-color .2s}
.subtask-input:focus{border-color:rgba(77,142,255,.4)}
.sub-add-btn{background:rgba(77,142,255,.15);border:1px solid rgba(77,142,255,.3);border-radius:10px;color:var(--blue);font-size:12px;font-weight:700;padding:8px 14px;cursor:pointer;transition:all .2s;font-family:'Outfit',sans-serif}
.sub-add-btn:hover{background:rgba(77,142,255,.25)}
.subtask-item{display:flex;align-items:center;gap:8px;padding:7px 10px;background:var(--bg4);border-radius:10px;margin-bottom:5px;border:1px solid var(--border);animation:jellyIn .4s cubic-bezier(.34,1.56,.64,1)}
@keyframes jellyIn{0%{opacity:0;transform:scale(.7) translateY(-8px)}60%{transform:scale(1.04) translateY(2px)}100%{opacity:1;transform:scale(1) translateY(0)}}
.sub-check{width:16px;height:16px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
.sub-check.done{background:var(--green);border-color:var(--green)}
.sub-check.done::after{content:'✓';color:#fff;font-size:9px;font-weight:800}
.subtask-title{flex:1;font-size:12px;font-weight:500;color:var(--text)}
.subtask-title.done{text-decoration:line-through;color:var(--muted)}
.sub-del{font-size:11px;color:var(--muted);cursor:pointer;transition:color .2s;padding:2px 4px}
.sub-del:hover{color:var(--red)}
.subtask-progress{display:flex;align-items:center;gap:6px;margin-top:4px}
.sub-prog-track{flex:1;background:var(--bg4);border-radius:10px;height:3px;overflow:hidden}
.sub-prog-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--cyan));border-radius:10px;transition:width .4s var(--ease)}
.sub-count{font-size:10px;color:var(--muted);font-weight:600}

/* CAT COLORS */
.cat-work{background:#4D8EFF}.cat-personal{background:#7C5CFC}.cat-health{background:#1AE47C}.cat-study{background:#FF9F1C}.cat-finance{background:#00D4FF}.cat-fitness{background:#FF4560}

/* PROGRESS RING */
.ring-wrap{position:relative;display:inline-flex;align-items:center;justify-content:center}
.ring-wrap svg{transform:rotate(-90deg)}
.ring-label{position:absolute;text-align:center}
.ring-pct{font-size:22px;font-weight:800;letter-spacing:-.03em}
.ring-sub{font-size:10px;color:var(--muted)}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(12px);z-index:100;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:22px;width:520px;max-width:93vw;padding:28px;position:relative;transform:translateY(24px) scale(.96);transition:transform .3s cubic-bezier(.34,1.56,.64,1);max-height:90vh;overflow-y:auto}
.modal-overlay.open .modal{transform:none}
.modal-close{position:absolute;top:16px;right:16px;width:30px;height:30px;border-radius:9px;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;color:var(--muted);transition:all .2s}
.modal-close:hover{background:var(--bg4);color:var(--text)}
.modal-title{font-size:19px;font-weight:800;margin-bottom:22px;letter-spacing:-.02em}
.form-group{margin-bottom:15px}
.form-label{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:7px;display:block}
.form-input,.form-select,.form-textarea{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:11px 15px;color:var(--text);font-size:14px;font-family:'Outfit',sans-serif;outline:none;transition:all .2s}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:rgba(77,142,255,.5);box-shadow:0 0 0 4px rgba(77,142,255,.08)}
.form-textarea{resize:vertical;min-height:80px}
.form-select option{background:var(--bg3);color:var(--text)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}

/* AI CHAT PANEL */
.ai-chat-wrap{height:100%;display:flex;flex-direction:column}
.ai-messages{flex:1;overflow-y:auto;padding:4px 0;display:flex;flex-direction:column;gap:12px;min-height:0}
.ai-msg{max-width:85%;animation:msgSlide .3s var(--ease)}
@keyframes msgSlide{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.ai-msg.user{align-self:flex-end}
.ai-msg.user .msg-bubble{background:linear-gradient(135deg,var(--blue),var(--purple));color:#fff;border-radius:18px 18px 5px 18px}
.ai-msg.bot .msg-bubble{background:var(--bg3);border:1px solid var(--border);border-radius:18px 18px 18px 5px}
.msg-bubble{padding:12px 16px;font-size:13px;line-height:1.6}
.msg-bubble b{font-weight:700}
.msg-time{font-size:10px;color:var(--muted);margin-top:4px;padding:0 4px}
.ai-input-row{display:flex;gap:9px;padding-top:12px;border-top:1px solid var(--border);flex-shrink:0}
.ai-input{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:13px;padding:11px 15px;color:var(--text);font-size:13px;font-family:'Outfit',sans-serif;outline:none;transition:border-color .2s;resize:none}
.ai-input:focus{border-color:rgba(124,92,252,.5)}
.ai-send{background:linear-gradient(135deg,var(--purple),var(--blue));border:none;border-radius:13px;padding:11px 16px;color:#fff;cursor:pointer;font-size:15px;transition:all .2s;box-shadow:0 4px 14px var(--glow-purple)}
.ai-send:hover{transform:scale(1.05)}
.typing-indicator{display:flex;gap:5px;align-items:center;padding:12px 16px}
.dot{width:7px;height:7px;background:var(--muted);border-radius:50%;animation:bounce .9s infinite}
.dot:nth-child(2){animation-delay:.15s}.dot:nth-child(3){animation-delay:.3s}
@keyframes bounce{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-8px)}}

/* AI SUGGESTIONS */
.ai-sug{background:linear-gradient(135deg,rgba(124,92,252,.1),rgba(77,142,255,.06));border:1px solid rgba(124,92,252,.2);border-radius:14px;padding:16px;margin-bottom:10px;cursor:pointer;transition:all .2s}
.ai-sug:hover{border-color:rgba(124,92,252,.4);transform:translateX(3px)}
.ai-sug-title{font-size:13px;font-weight:700;margin-bottom:5px;display:flex;align-items:center;gap:8px}
.ai-sug-body{font-size:12px;color:var(--muted);line-height:1.6}
.ai-badge{font-size:10px;padding:2px 9px;border-radius:20px;background:rgba(124,92,252,.2);color:var(--purple);font-weight:700}

/* POMODORO */
.pomo-time{font-family:'JetBrains Mono',monospace;font-size:68px;font-weight:700;background:linear-gradient(135deg,var(--cyan),var(--blue));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-.02em;line-height:1}
.pomo-label{font-size:13px;color:var(--muted);margin:8px 0 24px;font-weight:500}
.pomo-btns{display:flex;gap:10px;justify-content:center}
.tabs{display:flex;gap:4px;background:var(--bg3);border-radius:14px;padding:4px;margin-bottom:20px}
.tab{flex:1;text-align:center;padding:9px;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;color:var(--muted);transition:all .25s}
.tab.active{background:var(--bg2);color:var(--text);box-shadow:0 2px 8px rgba(0,0,0,.25)}

/* SKILL CARDS */
.skill-card{background:var(--bg3);border:1px solid var(--border);border-radius:16px;padding:18px;transition:all .25s;cursor:pointer}
.skill-card:hover{border-color:rgba(77,142,255,.3);transform:translateY(-3px);box-shadow:0 12px 32px rgba(0,0,0,.2)}
.skill-icon{width:42px;height:42px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:21px;flex-shrink:0}
.skill-progress{background:var(--bg4);border-radius:20px;height:5px;overflow:hidden;margin:9px 0}
.skill-fill{height:100%;border-radius:20px;background:linear-gradient(90deg,var(--blue),var(--cyan))}
.skill-tag{font-size:10px;padding:3px 9px;border-radius:7px;background:var(--bg4);color:var(--muted);font-weight:600}

/* HABIT */
.habit-emoji-opt{font-size:22px;padding:6px 10px;border-radius:10px;cursor:pointer;border:2px solid transparent;background:var(--bg3);transition:all .2s;user-select:none}
.habit-emoji-opt:hover{background:var(--bg4);border-color:rgba(77,142,255,.3)}
.habit-emoji-opt.active{border-color:var(--blue);background:rgba(77,142,255,.12)}
.habit-row{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border)}
.habit-row:last-child{border-bottom:none}
.habit-dot{width:22px;height:22px;border-radius:7px;background:var(--bg4);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;font-size:10px;font-weight:700}
.habit-dot.done{background:rgba(26,228,124,.15);border:1px solid rgba(26,228,124,.3);color:var(--green)}
.habit-dot:hover{background:var(--glass2)}

/* HEATMAP */
.heatmap{display:grid;grid-template-columns:repeat(52,1fr);gap:3px;padding:8px 0}
.hm-cell{aspect-ratio:1;border-radius:3px;transition:transform .2s}
.hm-cell:hover{transform:scale(1.5)}
.hm-0{background:var(--bg4)}.hm-1{background:rgba(77,142,255,.25)}.hm-2{background:rgba(77,142,255,.5)}.hm-3{background:rgba(77,142,255,.75)}.hm-4{background:rgba(77,142,255,1)}

/* BADGE */
.badge-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.badge-item{background:var(--bg3);border:1px solid var(--border);border-radius:14px;padding:16px;text-align:center;transition:all .25s}
.badge-item:hover{border-color:rgba(255,159,28,.3);transform:translateY(-2px)}
.badge-item.locked{opacity:.3;filter:grayscale(1)}
.badge-icon{font-size:30px;margin-bottom:8px}

/* XP */
.xp-bar{background:var(--bg3);border-radius:20px;height:8px;overflow:hidden}
.xp-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--cyan));border-radius:20px;transition:width .8s var(--ease)}

/* ROADMAP */
.roadmap-step{display:flex;gap:16px;margin-bottom:22px;position:relative}
.roadmap-step::before{content:'';position:absolute;left:16px;top:34px;width:2px;height:calc(100% + 4px);background:var(--border)}
.roadmap-step:last-child::before{display:none}
.step-bullet{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;z-index:1;border:2px solid var(--border)}
.step-bullet.done{background:var(--green);border-color:var(--green);color:#fff;box-shadow:0 0 14px rgba(26,228,124,.3)}
.step-bullet.active{background:var(--blue);border-color:var(--blue);color:#fff;box-shadow:0 0 14px var(--glow-blue)}
.step-bullet.pending{background:var(--bg3);color:var(--muted)}

/* QUOTE CARD */
.quote-card{background:linear-gradient(135deg,rgba(77,142,255,.08),rgba(124,92,252,.06));border:1px solid rgba(77,142,255,.12);border-radius:18px;padding:24px;text-align:center;margin-bottom:14px}
.quote-text{font-size:15px;font-style:italic;line-height:1.8;margin-bottom:12px}
.quote-author{font-size:12px;color:var(--muted)}

/* TOAST */
.toast-wrap{position:fixed;top:20px;right:20px;z-index:300;display:flex;flex-direction:column;gap:8px;pointer-events:none}
.toast{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:13px 17px;display:flex;align-items:center;gap:10px;font-size:13px;pointer-events:all;animation:toastIn .35s cubic-bezier(.34,1.56,.64,1);min-width:270px;backdrop-filter:blur(20px);font-weight:500}
.toast.success{border-color:rgba(26,228,124,.3);background:rgba(26,228,124,.06)}
.toast.error{border-color:rgba(255,69,96,.3);background:rgba(255,69,96,.06)}
.toast.info{border-color:rgba(77,142,255,.3);background:rgba(77,142,255,.06)}
@keyframes toastIn{from{opacity:0;transform:translateX(30px) scale(.9)}to{opacity:1;transform:translateX(0) scale(1)}}
.toast-dismiss{margin-left:auto;cursor:pointer;color:var(--muted);font-size:14px;opacity:.5}
.toast-dismiss:hover{opacity:1}

/* FOCUS MODE OVERLAY */
.focus-overlay{position:fixed;inset:0;background:rgba(0,0,0,.97);z-index:500;display:none;flex-direction:column;align-items:center;justify-content:center;backdrop-filter:blur(20px)}
.focus-overlay.active{display:flex;animation:focusIn .5s var(--ease)}
@keyframes focusIn{from{opacity:0}to{opacity:1}}
.focus-time-display{font-family:'JetBrains Mono',monospace;font-size:96px;font-weight:700;background:linear-gradient(135deg,var(--cyan),var(--blue),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-.04em;line-height:1;margin-bottom:16px}
.focus-task-name{font-size:18px;color:var(--muted);margin-bottom:40px;max-width:500px;text-align:center}
.focus-bar-wrap{width:320px;height:4px;background:rgba(255,255,255,.1);border-radius:4px;margin-bottom:40px;overflow:hidden}
.focus-progress{height:100%;background:linear-gradient(90deg,var(--cyan),var(--purple));border-radius:4px;transition:width 1s linear}
.focus-controls{display:flex;gap:14px}
.focus-btn{padding:14px 28px;border-radius:16px;font-size:14px;font-weight:700;cursor:pointer;border:1px solid;transition:all .2s;font-family:'Outfit',sans-serif}
.focus-btn.primary{background:linear-gradient(135deg,var(--blue),var(--purple));border-color:transparent;color:#fff;box-shadow:0 8px 24px var(--glow-blue)}
.focus-btn.ghost{background:transparent;border-color:rgba(255,255,255,.15);color:var(--muted)}
.focus-btn.ghost:hover{background:rgba(255,255,255,.05);color:var(--text)}
.focus-close{position:absolute;top:24px;right:28px;font-size:24px;cursor:pointer;color:var(--muted);opacity:.5;transition:opacity .2s}
.focus-close:hover{opacity:1}
.focus-particles{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.particle{position:absolute;border-radius:50%;animation:particleFloat linear infinite;opacity:0}
@keyframes particleFloat{0%{transform:translateY(100vh) scale(0);opacity:0}10%{opacity:.6}90%{opacity:.3}100%{transform:translateY(-100px) scale(1);opacity:0}}

/* CUSTOMISE PANEL */
.cust-panel{position:fixed;right:0;top:0;height:100vh;width:300px;background:var(--bg2);border-left:1px solid var(--border);z-index:150;transform:translateX(100%);transition:transform .35s var(--ease);overflow-y:auto;padding:24px}
.cust-panel.open{transform:translateX(0)}
.cust-title{font-size:16px;font-weight:800;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between}
.cust-section{margin-bottom:20px}
.cust-sec-title{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px}
.color-swatches{display:flex;gap:8px;flex-wrap:wrap}
.swatch{width:32px;height:32px;border-radius:10px;cursor:pointer;border:2px solid transparent;transition:all .2s}
.swatch:hover{transform:scale(1.1)}
.swatch.active{border-color:var(--text)}
.name-input{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:11px;padding:10px 14px;color:var(--text);font-size:14px;font-family:'Outfit',sans-serif;outline:none;transition:border-color .2s}
.name-input:focus{border-color:rgba(77,142,255,.5)}

/* GOOGLE LOGIN SCREEN */
.login-screen{position:fixed;inset:0;background:var(--bg);z-index:1000;display:flex;align-items:center;justify-content:center;flex-direction:column}
.login-card{background:var(--bg2);border:1px solid var(--border);border-radius:28px;padding:48px 44px;width:400px;max-width:92vw;text-align:center;position:relative;overflow:hidden}
.login-card::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:200px;height:200px;background:radial-gradient(circle,var(--glow-blue),transparent 70%);pointer-events:none}
.login-logo{width:64px;height:64px;border-radius:20px;background:linear-gradient(135deg,var(--blue),var(--purple));display:flex;align-items:center;justify-content:center;font-size:30px;margin:0 auto 20px;box-shadow:0 0 30px var(--glow-blue)}
.login-title{font-size:26px;font-weight:800;margin-bottom:6px;letter-spacing:-.03em}
.login-sub{font-size:13px;color:var(--muted);margin-bottom:32px;line-height:1.6}
.google-btn{display:flex;align-items:center;justify-content:center;gap:12px;width:100%;padding:15px;background:var(--bg3);border:1px solid var(--border);border-radius:15px;cursor:pointer;font-size:15px;font-weight:700;color:var(--text);transition:all .25s;font-family:'Outfit',sans-serif;margin-bottom:12px}
.google-btn:hover{background:var(--bg4);border-color:rgba(77,142,255,.4);box-shadow:0 8px 24px rgba(0,0,0,.2);transform:translateY(-2px)}
.google-icon{width:22px;height:22px;flex-shrink:0}
.guest-btn{font-size:13px;color:var(--muted);cursor:pointer;transition:color .2s;background:none;border:none;font-family:'Outfit',sans-serif;font-weight:600}
.guest-btn:hover{color:var(--text)}

/* SCROLLABLE */
.scroll-y{overflow-y:auto;max-height:400px}
/* RESPONSIVE */
@media(max-width:820px){
  .sidebar{position:fixed;left:-280px;z-index:200;transition:left .35s var(--ease)}
  .sidebar.mobile-open{left:0}.stats-grid{grid-template-columns:1fr 1fr}
  .grid-2,.grid-3{grid-template-columns:1fr}
  .badge-grid{grid-template-columns:1fr 1fr}
  .ai-view-grid{grid-template-columns:1fr!important}
}
/* EMPTY */
.empty-state{text-align:center;padding:48px 20px;color:var(--muted)}
.empty-icon{font-size:44px;margin-bottom:14px;opacity:.4}
.empty-text{font-size:14px;margin-bottom:18px}
/* RANGE */
input[type=range]{-webkit-appearance:none;width:100%;height:4px;border-radius:4px;background:var(--bg4);outline:none}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;border-radius:50%;background:var(--blue);cursor:pointer;border:2px solid var(--bg2)}
canvas{max-width:100%}
/* FOCUS SHIMMER */
.focus-shimmer{position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,var(--blue),var(--purple),var(--cyan),transparent);background-size:200% 100%;animation:shimmer 2.5s infinite;opacity:.7}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* CUSTOMIZE TOGGLE */
.cust-toggle{position:fixed;right:0;top:50%;transform:translateY(-50%);background:var(--bg2);border:1px solid var(--border);border-right:none;border-radius:12px 0 0 12px;padding:12px 10px;cursor:pointer;z-index:140;writing-mode:vertical-rl;font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.05em;transition:all .2s}
.cust-toggle:hover{color:var(--text);background:var(--bg3)}

</style>
</head>
<body>

<!-- ===== LOGIN SCREEN ===== -->
<div class="login-screen" id="loginScreen">
  <div class="login-card">
    <div class="login-logo">⚡</div>
    <div class="login-title">TaskFlow AI</div>
    <div class="login-sub">Your intelligent productivity companion.<br>Sign in to sync your tasks across devices.</div>
    <button class="google-btn" onclick="googleLogin()">
      <svg class="google-icon" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.6 20.1H42V20H24v8h11.3C33.7 32.9 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.1 8.1 2.9l5.7-5.7C34.4 6.5 29.5 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.6-.4-3.9z"/><path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16 19 13 24 13c3.1 0 5.9 1.1 8.1 2.9l5.7-5.7C34.4 6.5 29.5 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/><path fill="#4CAF50" d="M24 44c5.4 0 10.3-2.1 14-5.4l-6.5-5.5C29.5 34.8 26.9 36 24 36c-5.2 0-9.6-3-11.3-7.3L6.2 34c3.3 6.6 10 11 17.8 11z"/><path fill="#1976D2" d="M43.6 20.1H42V20H24v8h11.3c-.7 2.1-2 3.9-3.8 5.1l6.5 5.5C37.8 40.1 44 35 44 24c0-1.3-.1-2.6-.4-3.9z"/></svg>
      Continue with Google
    </button>
    <button class="guest-btn" onclick="guestLogin()">Continue as Guest →</button>
  </div>
</div>

<!-- ===== TOAST CONTAINER ===== -->
<div class="toast-wrap" id="toastWrap"></div>

<!-- ===== FOCUS MODE OVERLAY ===== -->
<div class="focus-overlay" id="focusOverlay">
  <div class="focus-particles" id="focusParticles"></div>
  <span class="focus-close" onclick="exitFocus()">✕</span>
  <div style="font-size:13px;color:var(--muted);margin-bottom:8px;font-weight:600;letter-spacing:.05em">FOCUS MODE</div>
  <div class="focus-time-display" id="focusTime">25:00</div>
  <div class="focus-task-name" id="focusTaskName">Deep Work Session</div>
  <div class="focus-bar-wrap"><div class="focus-progress" id="focusProgress" style="width:0%"></div></div>
  <div class="focus-controls">
    <button class="focus-btn primary" id="focusStartBtn" onclick="toggleFocusTimer()">▶ Start</button>
    <button class="focus-btn ghost" onclick="resetFocusTimer()">↺ Reset</button>
    <button class="focus-btn ghost" onclick="exitFocus()">Exit</button>
  </div>
  <div class="focus-shimmer"></div>
</div>

<!-- ===== ADD TASK MODAL ===== -->
<div class="modal-overlay" id="taskModal" onclick="if(event.target===this)closeModal('taskModal')">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('taskModal')">✕</button>
    <div class="modal-title">✦ New Task</div>
    <div class="form-group">
      <label class="form-label">Task Title</label>
      <input class="form-input" id="modalTitle" placeholder="What needs to be done?"/>
    </div>
    <div class="form-group">
      <label class="form-label">Description</label>
      <textarea class="form-textarea" id="modalDesc" placeholder="Add details..."></textarea>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Category</label>
        <select class="form-select" id="modalCat">
          <option value="work">💼 Work</option>
          <option value="personal">👤 Personal</option>
          <option value="study">📚 Study</option>
          <option value="health">❤️ Health</option>
          <option value="finance">💰 Finance</option>
          <option value="fitness">💪 Fitness</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Priority</label>
        <select class="form-select" id="modalPri">
          <option value="high">🔴 High</option>
          <option value="mid">🟡 Medium</option>
          <option value="low">🟢 Low</option>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Due Date</label>
        <input class="form-input" type="date" id="modalDue"/>
      </div>
      <div class="form-group">
        <label class="form-label">Est. Time (hrs)</label>
        <input class="form-input" type="number" id="modalTime" placeholder="2" min="0.5" step="0.5"/>
      </div>
    </div>
    <button class="btn-primary" style="width:100%;margin-top:8px;font-size:14px;padding:13px" onclick="saveTask()">Add Task ✦</button>
  </div>
</div>

<!-- ===== HABIT MODAL ===== -->
<div class="modal-overlay" id="habitModal" onclick="if(event.target===this)closeModal('habitModal')">
  <div class="modal" style="width:420px">
    <div class="modal-close" onclick="closeModal('habitModal')">✕</div>
    <div class="modal-title">✦ Add New Habit</div>
    <div class="form-group">
      <label class="form-label">Habit Name</label>
      <input class="form-input" id="habitName" placeholder="e.g. Morning Meditation"/>
    </div>
    <div class="form-group">
      <label class="form-label">Emoji / Icon</label>
      <div style="display:flex;gap:8px;flex-wrap:wrap" id="habitEmojiPicker">
        <span class="habit-emoji-opt active" onclick="selectHabitEmoji(this,'🧘')">🧘</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'📚')">📚</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'💪')">💪</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'🏃')">🏃</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'💧')">💧</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'🌿')">🌿</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'✍️')">✍️</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'🎯')">🎯</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'😴')">😴</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'🍎')">🍎</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'🚫')">🚫</span>
        <span class="habit-emoji-opt" onclick="selectHabitEmoji(this,'🎵')">🎵</span>
      </div>
    </div>
    <button class="btn-primary" style="width:100%;margin-top:8px;font-size:14px;padding:13px" onclick="saveHabit()">Add Habit ✦</button>
  </div>
</div>

<!-- ===== CUSTOMISE PANEL ===== -->
<div class="cust-toggle" id="custToggle" onclick="toggleCust()">C U S T O M I Z E</div>
<div class="cust-panel" id="custPanel">
  <div class="cust-title">
    Customize
    <span style="cursor:pointer;color:var(--muted);font-size:14px" onclick="toggleCust()">✕</span>
  </div>
  <div class="cust-section">
    <div class="cust-sec-title">Your Name</div>
    <input class="name-input" id="custName" placeholder="Enter your name..." oninput="updateName(this.value)"/>
