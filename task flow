// ===================== AUDIO TUNES =====================
let currentTune = 'none';
function playTuneIfSet() { if(currentTune!=='none') playTune(currentTune); }
function stopTune() { if(activeNode){ try{activeNode.stop()}catch(e){} activeNode=null; } }
function playTune(type) {
  currentTune=type; stopTune();
  if(type==='none'){ showToast('Sound off 🔇','info'); return; }
  try {
    audioCtx = audioCtx || new (window.AudioContext||window.webkitAudioContext)();
    const master = audioCtx.createGain(); master.gain.value=0.18; master.connect(audioCtx.destination);
    if(type==='rain') generateRain(master);
    else if(type==='ocean') generateOcean(master);
    else if(type==='lofi') generateLofi(master);
    showToast({rain:'🌧 Rain playing...',ocean:'🌊 Ocean waves...',lofi:'🎵 Lo-Fi on...'}[type]||'Playing','info');
  } catch(e){ showToast('Enable audio in browser settings','info'); }
}
function generateRain(master) {
  const src = audioCtx.createBufferSource();
  const buf = audioCtx.createBuffer(1, audioCtx.sampleRate*3, audioCtx.sampleRate);
  const data = buf.getChannelData(0);
  for(let i=0;i<data.length;i++) data[i]=(Math.random()*2-1)*0.5;
  const filter = audioCtx.createBiquadFilter(); filter.type='lowpass'; filter.frequency.value=700;
  src.buffer=buf; src.loop=true;
  src.connect(filter); filter.connect(master);
  src.start(); activeNode=src;
}
function generateOcean(master) {
  const src = audioCtx.createBufferSource();
  const buf = audioCtx.createBuffer(1, audioCtx.sampleRate*4, audioCtx.sampleRate);
  const data = buf.getChannelData(0);
  for(let i=0;i<data.length;i++){
    const t=i/audioCtx.sampleRate;
    data[i]=(Math.random()*2-1)*0.3*(0.5+0.5*Math.sin(t*0.3));
  }
  const filter = audioCtx.createBiquadFilter(); filter.type='lowpass'; filter.frequency.value=500;
  src.buffer=buf; src.loop=true; src.connect(filter); filter.connect(master);
  src.start(); activeNode=src;
}
function generateLofi(master) {
  const notes=[261.63,329.63,392,523.25,440,349.23,261.63,392];
  let i=0;
  function playNote(){
    const osc=audioCtx.createOscillator(),g=audioCtx.createGain();
    osc.type='triangle'; osc.frequency.value=notes[i%notes.length];
    g.gain.setValueAtTime(0,audioCtx.currentTime); g.gain.linearRampToValueAtTime(0.08,audioCtx.currentTime+0.05);
    g.gain.linearRampToValueAtTime(0,audioCtx.currentTime+0.55);
    osc.connect(g); g.connect(master);
    osc.start(); osc.stop(audioCtx.currentTime+0.6);
    i++; activeNode={stop:()=>{}};
  }
  playNote(); const id=setInterval(playNote,700);
  activeNode={stop:()=>clearInterval(id)};
}

// ===================== CHARTS =====================
function getRealWeeklyData() {
  const labels=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const done=Array(7).fill(0), added=Array(7).fill(0);
  const now=new Date();
  tasks.forEach(t=>{
    if(t.due){
      const d=new Date(t.due);
      const dayDiff=Math.floor((now-d)/(1000*60*60*24));
      if(dayDiff>=0&&dayDiff<7){
        const idx=6-dayDiff;
        added[idx]++;
        if(t.done) done[idx]++;
      }
    }
  });
  return {labels,done,added};
}
function getRealCategoryData() {
  const cats={work:0,personal:0,study:0,health:0,finance:0,fitness:0};
  tasks.forEach(t=>{if(cats[t.cat]!==undefined) cats[t.cat]++;});
  const filtered=Object.entries(cats).filter(([,v])=>v>0);
  return {
    labels:filtered.map(([k])=>k.charAt(0).toUpperCase()+k.slice(1)),
    data:filtered.map(([,v])=>v),
    colors:['rgba(77,142,255,.8)','rgba(124,92,252,.8)','rgba(255,159,28,.8)','rgba(26,228,124,.8)','rgba(0,212,255,.8)','rgba(255,69,96,.8)']
  };
}
let weekChartInst=null, monthChartInst=null, catChartInst=null;
function initCharts() {
  if(chartsInit) return; chartsInit=true;
  const defaults={color:'rgba(255,255,255,.65)',gridColor:'rgba(255,255,255,.05)'};
  const weekly=getRealWeeklyData();
  const catData=getRealCategoryData();
  // Weekly bar chart
  weekChartInst=new Chart(document.getElementById('weekChart'),{type:'bar',data:{labels:weekly.labels,datasets:[{label:'Done',data:weekly.done,backgroundColor:'rgba(77,142,255,.65)',borderRadius:8,borderSkipped:false},{label:'Due',data:weekly.added,backgroundColor:'rgba(124,92,252,.35)',borderRadius:8,borderSkipped:false}]},options:{responsive:true,plugins:{legend:{labels:{color:defaults.color,font:{size:11}}}},scales:{x:{ticks:{color:defaults.color},grid:{color:defaults.gridColor}},y:{ticks:{color:defaults.color,stepSize:1},grid:{color:defaults.gridColor}}}}});
  // Monthly line chart (real: last 6 months completion %)
  const months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const now=new Date(); const monthData=[];
  for(let i=5;i>=0;i--){
    const d=new Date(now.getFullYear(),now.getMonth()-i,1);
    const mTasks=tasks.filter(t=>t.due&&new Date(t.due).getMonth()===d.getMonth()&&new Date(t.due).getFullYear()===d.getFullYear());
    const pct=mTasks.length?Math.round((mTasks.filter(t=>t.done).length/mTasks.length)*100):0;
    monthData.push(pct);
  }
  const monthLabels=Array.from({length:6},(_,i)=>months[(now.getMonth()-5+i+12)%12]);
  monthChartInst=new Chart(document.getElementById('monthChart'),{type:'line',data:{labels:monthLabels,datasets:[{label:'Completion %',data:monthData,borderColor:'#4D8EFF',backgroundColor:'rgba(77,142,255,.1)',tension:.4,fill:true,pointBackgroundColor:'#4D8EFF',pointRadius:5}]},options:{responsive:true,plugins:{legend:{labels:{color:defaults.color,font:{size:11}}}},scales:{x:{ticks:{color:defaults.color},grid:{color:defaults.gridColor}},y:{min:0,max:100,ticks:{color:defaults.color},grid:{color:defaults.gridColor}}}}});
  // Category doughnut
  catChartInst=new Chart(document.getElementById('catChart'),{type:'doughnut',data:{labels:catData.labels.length?catData.labels:['No Tasks'],datasets:[{data:catData.data.length?catData.data:[1],backgroundColor:catData.colors,borderWidth:0,hoverOffset:8}]},options:{responsive:true,cutout:'68%',plugins:{legend:{labels:{color:defaults.color,font:{size:11}},position:'right'}}}});
  generateHeatmap();
}
function initHabitChart() {
  const existing=Chart.getChart('habitChart'); if(existing) existing.destroy();
  if(!habitsData.length) return;
  new Chart(document.getElementById('habitChart'),{type:'radar',data:{labels:habitsData.map(h=>(h.emoji||'')+(h.name.split(' ').slice(0,2).join(' '))),datasets:[{label:'Consistency %',data:habitsData.map(h=>Math.round((h.done.filter(Boolean).length/7)*100)),borderColor:'#7C5CFC',backgroundColor:'rgba(124,92,252,.12)',pointBackgroundColor:'#7C5CFC',pointRadius:4}]},options:{responsive:true,scales:{r:{ticks:{color:'rgba(255,255,255,.5)',backdropColor:'transparent'},grid:{color:'rgba(255,255,255,.06)'},pointLabels:{color:'rgba(255,255,255,.65)',font:{size:11}}}},plugins:{legend:{labels:{color:'rgba(255,255,255,.65)'}}}}});
}
function generateHeatmap() {
  const el=document.getElementById('heatmap');
  // Build real heatmap from task due dates
  const counts={};
  tasks.forEach(t=>{if(t.done&&t.due) counts[t.due]=(counts[t.due]||0)+1;});
  const cells=Array.from({length:364},(_,i)=>{
    const d=new Date(); d.setDate(d.getDate()-363+i);
    const key=d.toISOString().slice(0,10);
    const v=Math.min(counts[key]||0,4);
    return `<div class="hm-cell hm-${v}" title="${key}: ${counts[key]||0} completed"></div>`;
  });
  el.innerHTML=cells.join('');
}

