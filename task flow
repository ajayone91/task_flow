<script>
// ===================== AUTOSAVE STATE =====================
function loadState() {
  try {
    const saved = localStorage.getItem('tf_state_v2');
    if(saved) return JSON.parse(saved);
  } catch(e){}
  return null;
}
function saveState() {
  try {
    const state = { tasks, userName, theme: document.documentElement.dataset.theme||'dark', accentBlue, accentPurple, habitsData };
    localStorage.setItem('tf_state_v2', JSON.stringify(state));
  } catch(e){}
}

// ===================== STATE =====================
let saved = loadState();
let tasks = saved ? saved.tasks : [];
let habitsData = (saved && saved.habitsData) ? saved.habitsData : [];
